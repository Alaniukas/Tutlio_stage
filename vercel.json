{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "devCommand": null,
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self' https: data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https: blob:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https: wss: ws:; frame-src 'self' https:; worker-src 'self' blob:; base-uri 'self'; form-action 'self' https:; frame-ancestors 'self'; object-src 'none'; upgrade-insecure-requests"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "SAMEORIGIN"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/blog/:slug",
            "destination": "/api/blog-render?slug=:slug&locale=lt"
        },
        {
            "source": "/blog",
            "destination": "/api/blog-render?locale=lt"
        },
        {
            "source": "/:locale/blog/:slug",
            "destination": "/api/blog-render?slug=:slug&locale=:locale"
        },
        {
            "source": "/:locale/blog",
            "destination": "/api/blog-render?locale=:locale"
        },
        {
            "source": "/sitemap.xml",
            "destination": "/api/sitemap"
        },
        {
            "source": "/((?!api/|@|src/|assets/|node_modules/|\\.vite/|favicon\\.ico|favicon\\.svg|robots\\.txt|sitemap\\.xml|manifest\\.webmanifest).*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/auto-complete-sessions",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/send-reminders",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/payment-deadline-warnings",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/payment-after-lesson-reminders",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/expire-packages",
            "schedule": "0 */6 * * *"
        }
    ]
}