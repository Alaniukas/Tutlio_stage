{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "devCommand": null,
    "functions": {
        "api/page-render.ts": {
            "maxDuration": 30
        },
        "api/feature-render.ts": {
            "maxDuration": 30
        },
        "api/blog-render.ts": {
            "maxDuration": 30
        },
        "api/legal-render.ts": {
            "maxDuration": 30
        },
        "api/sitemap.ts": {
            "maxDuration": 30
        }
    },
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self' https: data: blob:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https: blob:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https: wss: ws:; frame-src 'self' https:; worker-src 'self' blob:; base-uri 'self'; form-action 'self' https:; frame-ancestors 'self'; object-src 'none'; upgrade-insecure-requests"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "SAMEORIGIN"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/robots.txt",
            "destination": "/api/robots"
        },
        {
            "source": "/sitemap.xml",
            "destination": "/api/sitemap"
        },
        {
            "source": "/llms.txt",
            "destination": "/api/llms-txt"
        },
        {
            "source": "/llms-full.txt",
            "destination": "/api/llms-txt"
        },
        {
            "source": "/((?!api/|@|src/|assets/|node_modules/|\\.vite/|favicon\\.ico|favicon\\.svg|robots\\.txt|sitemap\\.xml|manifest\\.webmanifest|llms\\.txt|llms-full\\.txt).*)",
            "destination": "/index.html"
        }
    ],
    "crons": [
        {
            "path": "/api/auto-complete-sessions",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/send-reminders",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/expire-packages",
            "schedule": "0 */6 * * *"
        },
        {
            "path": "/api/cleanup-whiteboard-data",
            "schedule": "20 * * * *"
        }
    ]
}
