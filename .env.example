#############################
# Supabase (frontend + API) #
#############################

# Public URL to your Supabase project (Project Settings → API → URL)
VITE_SUPABASE_URL=

# Public anon key for browser client (Project Settings → API → anon public)
VITE_SUPABASE_ANON_KEY=

# Optional: same as VITE_SUPABASE_URL, used by some server-side scripts
# (you can leave empty locally if VITE_SUPABASE_URL is set)
SUPABASE_URL=

# Service role key (NEVER expose in frontend, keep only in .env)
# Used by serverless API routes, reminders, Stripe webhook, etc.
SUPABASE_SERVICE_ROLE_KEY=

################
# Stripe keys  #
################

# Secret Stripe API key (test or live)
STRIPE_SECRET_KEY=

# Price IDs for subscriptions (optional locally unless testuojam prenumeratas)
STRIPE_MONTHLY_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=
# "Subscription only" plan (35 EUR/month, manual payments, no commission)
# Create a recurring price in Stripe under product prod_UOWf5Nqxf1wPIg
STRIPE_SUBSCRIPTION_ONLY_PRICE_ID=

# Stripe webhook secret (Dashboard → Developers → Webhooks)
STRIPE_WEBHOOK_SECRET=

#################################
# App URL / redirect konfiguracija
#################################

# Public app URL (prod: https://www.tutlio.lt, lokaliai: http://localhost:3000)
APP_URL=http://localhost:3000

# Vite pusėje naudojamas tas pats URL (galima palikti tuščią, jei vienodas su APP_URL)
VITE_APP_URL=http://localhost:3000

##################
# El. laiškai    #
##################

# Resend API key (production)
RESEND_API_KEY=

# Pasirenkama: atskiras key stage / lokaliam naudojimui
RESEND_API_KEY_STAGE=

# From adresas, kurį matys vartotojai
FROM_EMAIL=Tutlio <onboarding@tutlio.lt>

#########################
# Google Calendar OAuth #
#########################

# Google Cloud OAuth2 client (Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redirect URL, turi sutapti su Google konsolėje:
# pvz. https://www.tutlio.lt/api/google-calendar-callback arba http://localhost:3000/api/google-calendar-callback
GOOGLE_REDIRECT_URI=

########################
# Vidiniai / admin raktai
########################

# Platform admin API (tik serveris / Vercel — NIEKADA ne VITE_*). Senas VITE_ADMIN_SECRET vis dar skaitomas migracijai.
ADMIN_SECRET=
# @deprecated Naudokite ADMIN_SECRET. Jei vis dar nustatyta, API priims ir šį.
# VITE_ADMIN_SECRET=

########################
# Vercel Cron apsauga  #
########################

# Vercel automatiškai nustato CRON_SECRET production aplinkoje.
# Lokaliam testavimui galima palikti tuščią (cron endpointai veiks be auth).
CRON_SECRET=

########################
# Papildomi (nebūtini) #
########################

# Naudojama tik AI funkcijoms (dev tools), gali būti tuščia jei nenaudosi
GEMINI_API_KEY=

