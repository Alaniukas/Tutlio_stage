{
  "name": "tutlio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:frontend\" \"npm:dev:api\" --names \"VITE,API\" --prefix-colors \"cyan,magenta\"",
    "dev:prod": "zsh -ac 'set -a; source .env.local; export SUPABASE_URL=\"$VITE_SUPABASE_URL\"; export VITE_SUPABASE_URL=\"$VITE_SUPABASE_URL\"; export VITE_SUPABASE_ANON_KEY=\"$VITE_SUPABASE_ANON_KEY\"; npm run dev'",
    "dev:test": "zsh -ac 'set -a; source .env.local; export SUPABASE_URL=\"$TEST_SUPABASE_URL\"; export SUPABASE_SERVICE_ROLE_KEY=\"$TEST_SUPABASE_SERVICE_ROLE_KEY\"; export VITE_SUPABASE_URL=\"$TEST_SUPABASE_URL\"; export VITE_SUPABASE_ANON_KEY=\"$TEST_SUPABASE_ANON_KEY\"; npm run dev'",
    "dev:frontend": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "npx --yes vercel@latest dev --listen 3002 --yes --local",
    "start": "npx --yes vercel@latest dev --listen 3000 --yes --local",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "supabase:login": "npx supabase login",
    "supabase:link": "npx supabase link",
    "supabase:push": "npx supabase db push",
    "supabase:db": "npx supabase login && npx supabase db push",
    "email:product-update": "tsx scripts/email-product-update.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docxtemplater": "^3.68.6",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "pdf-lib": "^1.17.1",
    "pizzip": "^3.2.0",
    "react": "^19.2.4",
    "react-big-calendar": "^1.19.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "resend": "^6.9.2",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.3.7",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.0"
  }
}
